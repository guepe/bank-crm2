{% extends 'base.html.twig' %}

{% block title %}Leads{% endblock %}

{% block body %}
    <div class="section-head">
        <div>
            <p class="muted">Module CRM</p>
            <h1>Leads</h1>
        </div>
        <a class="button-link" href="{{ path('app_lead_new') }}">Nouveau lead</a>
    </div>

    <div class="section-card">
        <form method="get" class="stack compact">
            <div class="filter-grid">
                <div class="field">
                    <label for="lead-search">Rechercher un lead</label>
                    <input id="lead-search" type="search" name="q" value="{{ search|default('') }}" placeholder="Nom, ville, type, banque, statut">
                </div>
                <div class="field">
                    <label for="lead-city">Ville</label>
                    <select id="lead-city" name="city">
                        <option value="">Toutes les villes</option>
                        {% for city in filter_options.cities %}
                            <option value="{{ city }}" {% if filters.city == city %}selected{% endif %}>{{ city }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="lead-type">Type</label>
                    <select id="lead-type" name="type">
                        <option value="">Tous les types</option>
                        {% for type in filter_options.types %}
                            <option value="{{ type }}" {% if filters.type == type %}selected{% endif %}>{{ type }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="field">
                    <label for="lead-status">Statut</label>
                    <select id="lead-status" name="status">
                        <option value="">Tous les statuts</option>
                        {% for status_value, status_label in filter_options.statuses %}
                            <option value="{{ status_value }}" {% if filters.status == status_value %}selected{% endif %}>{{ status_label }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="actions">
                <button type="submit">Rechercher</button>
                {% if search is not empty or filters.city is not empty or filters.type is not empty or filters.status is not empty %}
                    <a class="button-link secondary" href="{{ path('app_lead_index') }}">Effacer</a>
                {% endif %}
            </div>
        </form>

        {% if search is not empty or filters.city is not empty or filters.type is not empty or filters.status is not empty %}
            <div class="active-filters">
                {% if search is not empty %}
                    <span class="filter-pill">Recherche : {{ search }}</span>
                {% endif %}
                {% if filters.city is not empty %}
                    <span class="filter-pill">Ville : {{ filters.city }}</span>
                {% endif %}
                {% if filters.type is not empty %}
                    <span class="filter-pill">Type : {{ filters.type }}</span>
                {% endif %}
                {% if filters.status is not empty %}
                    <span class="filter-pill">Statut : {{ filter_options.statuses[filters.status] }}</span>
                {% endif %}
            </div>
        {% endif %}

        <table class="data-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Type</th>
                    <th>Statut</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for lead in leads %}
                    <tr>
                        <td>{{ lead.name }}</td>
                        <td>{{ lead.city ?: '—' }}</td>
                        <td>{{ lead.type ?: '—' }}</td>
                        <td><span class="status-pill status-{{ lead.status }}">{{ lead.statusLabel }}</span></td>
                        <td><a href="{{ path('app_lead_show', {id: lead.id}) }}">Ouvrir</a></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="muted">Aucun lead ne correspond a la recherche ou aux filtres actifs.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
