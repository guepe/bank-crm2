{% extends 'base.html.twig' %}

{% block title %}Mon dossier{% endblock %}

{% block body %}
    <div class="section-head">
        <div>
            <p class="muted">Portail client</p>
            <h1>Mon dossier</h1>
        </div>
        <a class="button-link secondary" href="{{ path('app_portal_dashboard') }}">Retour</a>
    </div>

    <div class="section-card form-shell">
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="actions">
                <button type="submit">Mettre a jour</button>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
