{% extends 'base.html.twig' %}

{% block title %}Changer mon mot de passe{% endblock %}

{% block body %}
    <div class="topline">
        <p class="muted">Portail client</p>
        <h1>Changer mon mot de passe</h1>
    </div>

    <section class="section-card form-shell">
        {{ form_start(form) }}
            {{ form_row(form.plainPassword.first) }}
            {{ form_row(form.plainPassword.second) }}
            <div class="actions">
                <button type="submit">Enregistrer</button>
                <a class="button-link secondary" href="{{ path('app_portal_dashboard') }}">Annuler</a>
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
