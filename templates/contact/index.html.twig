{% extends 'base.html.twig' %}

{% block title %}Contacts{% endblock %}

{% block body %}
    <div class="section-head">
        <div>
            <p class="muted">Module CRM</p>
            <h1>Contacts</h1>
        </div>
        <a class="button-link" href="{{ path('app_contact_new') }}">Nouveau contact</a>
    </div>

    <div class="section-card">
        <form method="get" class="stack compact">
            <div class="field">
                <label for="contact-search">Rechercher un contact</label>
                <input id="contact-search" type="search" name="q" value="{{ search|default('') }}" placeholder="Nom, prenom, email, ville">
            </div>
            <div class="actions">
                <button type="submit">Rechercher</button>
                {% if search is not empty %}
                    <a class="button-link secondary" href="{{ path('app_contact_index') }}">Effacer</a>
                {% endif %}
            </div>
        </form>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Ville</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for contact in contacts %}
                    <tr>
                        <td>{{ contact }}</td>
                        <td>{{ contact.email ?: '—' }}</td>
                        <td>{{ contact.city ?: '—' }}</td>
                        <td><a href="{{ path('app_contact_show', {id: contact.id}) }}">Ouvrir</a></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="muted">Aucun contact.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
