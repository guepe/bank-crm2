{% extends 'base.html.twig' %}

{% block title %}Comptes{% endblock %}

{% block body %}
    <div class="section-head">
        <div>
            <p class="muted">Module CRM</p>
            <h1>Comptes</h1>
        </div>
        <a class="button-link" href="{{ path('app_account_new') }}">Nouveau compte</a>
    </div>

    <div class="section-card">
        <form method="get" class="stack compact">
            <div class="field">
                <label for="account-search">Rechercher un compte</label>
                <input id="account-search" type="search" name="q" value="{{ search|default('') }}" placeholder="Nom, ville, type">
            </div>
            <div class="actions">
                <button type="submit">Rechercher</button>
                {% if search is not empty %}
                    <a class="button-link secondary" href="{{ path('app_account_index') }}">Effacer</a>
                {% endif %}
            </div>
        </form>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Ville</th>
                    <th>Type</th>
                    <th>Contacts</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for account in accounts %}
                    <tr>
                        <td>{{ account.name }}</td>
                        <td>{{ account.city ?: '—' }}</td>
                        <td>{{ account.type ?: '—' }}</td>
                        <td>{{ account.contacts|length }}</td>
                        <td><a href="{{ path('app_account_show', {id: account.id}) }}">Ouvrir</a></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="muted">Aucun compte.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
