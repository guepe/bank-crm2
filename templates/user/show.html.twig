{% extends 'base.html.twig' %}

{% block title %}{{ managed_user.username }}{% endblock %}

{% block body %}
    <div class="section-head">
        <div>
            <p class="muted">Utilisateur</p>
            <h1>{{ managed_user.username }}</h1>
        </div>
        <div class="actions">
            <a class="button-link secondary" href="{{ path('app_user_edit', {id: managed_user.id}) }}">Modifier</a>
        </div>
    </div>

    <section class="section-card">
        <dl class="info-list">
            <div><dt>Email</dt><dd>{{ managed_user.email ?: '—' }}</dd></div>
            <div><dt>Roles</dt><dd>{{ managed_user.roleLabels|join(', ') ?: '—' }}</dd></div>
            <div><dt>Actif</dt><dd>{{ managed_user.enabled ? 'Oui' : 'Non' }}</dd></div>
            <div><dt>Type</dt><dd>{% if managed_user.clientUser %}Client{% else %}Interne{% endif %}</dd></div>
            <div><dt>Contact lie</dt><dd>{% if managed_user.contact %}<a href="{{ path('app_contact_show', {id: managed_user.contact.id}) }}">{{ managed_user.contact }}</a>{% else %}—{% endif %}</dd></div>
        </dl>
    </section>

    <form method="post" action="{{ path('app_user_delete', {id: managed_user.id}) }}" onsubmit="return confirm('Supprimer cet utilisateur ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ managed_user.id) }}">
        <button type="submit" class="danger">Supprimer</button>
    </form>
{% endblock %}
